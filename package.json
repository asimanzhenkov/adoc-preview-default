{
  "name": "adoc-preview-default",
  "displayName": "AsciiDoc Default Preview",
  "description": "Opens .adoc files in preview by default with an Edit button to switch to text editor",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "adocPreview.preview",
        "displayName": "AsciiDoc Preview",
        "selector": [
          { "filenamePattern": "*.adoc" },
          { "filenamePattern": "*.asciidoc" },
          { "filenamePattern": "*.ad" }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "adocPreview.openTextEditor",
        "title": "Edit Source",
        "icon": "$(edit)"
      },
      {
        "command": "adocPreview.openPreview",
        "title": "Open AsciiDoc Preview",
        "icon": "$(preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "adocPreview.openTextEditor",
          "when": "activeCustomEditorId == 'adocPreview.preview'",
          "group": "navigation@1"
        },
        {
          "command": "adocPreview.openPreview",
          "when": "editorLangId == asciidoc && activeCustomEditorId != 'adocPreview.preview'",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "AsciiDoc Default Preview",
      "properties": {
        "adocPreview.openPreviewByDefault": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open .adoc files in preview mode instead of text editor"
        },
        "adocPreview.liveReload": {
          "type": "boolean",
          "default": true,
          "description": "Update preview as you type (live reload)"
        },
        "adocPreview.liveReloadDebounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay in milliseconds for live reload"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "@asciidoctor/core": "^3.0.2"
  }
}
